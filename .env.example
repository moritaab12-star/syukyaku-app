# クライアント・サーバ共通（Supabase）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバのみ（管理 API・公開バッチ・/p のサーバー取得。本番 Vercel にも必須）
SUPABASE_SERVICE_ROLE_KEY=

# 管理画面 API（本番では必須推奨）
ADMIN_API_SECRET=

# 本番サイト URL（サイトマップ・canonical 等）
NEXT_PUBLIC_SITE_URL=

# Vercel Cron: /api/cron/publish-one
CRON_SECRET=

# 任意: LP スコア API
GEMINI_API_KEY=
# 任意: FVキャッチ生成（未設定時は GEMINI_LP_MODEL → gemini-1.5-flash）
# GEMINI_FV_CATCH_MODEL=gemini-1.5-flash
# 任意: LP UI コピー一式（lp_ui_copy JSON、未設定時は GEMINI_FV_CATCH_MODEL → GEMINI_LP_MODEL）
# GEMINI_LP_UI_COPY_MODEL=gemini-1.5-flash
# 任意: ヒーロー画像プロンプト用（未設定時は gemini-1.5-pro）
# GEMINI_HERO_PROMPT_MODEL=gemini-1.5-pro

# Vertex AI Imagen 3（/api/generate-lp・/api/generate のヒーロー生成）。AI Studio の GEMINI_API_KEY とは別。GCP 課金・権限が必要。
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# VERTEX_AI_LOCATION=us-central1
# VERTEX_IMAGEN_MODEL=imagen-3.0-generate-001
# ローカル: サービスアカウント JSON へのパス
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\sa.json
# Vercel 等: JSON 文字列をそのまま（改行なし推奨）
# VERTEX_GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# 任意: /api/generate・需要リサーチ（Perplexity）
PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=

# 任意: LP メトリクステーブル名
LP_METRICS_TABLE=

# --- 廃止済み（設定不要・本番から削除すること）---
# WORDPRESS_URL=
# WORDPRESS_USERNAME=
# WORDPRESS_APP_PASSWORD=
